-- LOGIQUE
local function updateOnBtn()
    if desyncOn then
        onBtn.Text="ON"
        TweenService:Create(onBtn,TweenInfo.new(0.2),{BackgroundColor3=GN}):Play()
        TweenService:Create(ms,TweenInfo.new(0.2),{Color=GN}):Play()
        titleLbl.Text="Uchiwa Desync [ON]"
    else
        onBtn.Text="OFF"
        TweenService:Create(onBtn,TweenInfo.new(0.2),{BackgroundColor3=RD}):Play()
        TweenService:Create(ms,TweenInfo.new(0.2),{Color=AC}):Play()
        titleLbl.Text="Uchiwa Desync"
    end
end

onBtn.MouseButton1Click:Connect(function()
    if desyncOn then deactivateDesync() else activateDesync() end
    updateOnBtn()
end)

autoBtn.MouseButton1Click:Connect(function()
    autoOn=not autoOn
    if autoOn then
        autoBtn.Text="AUTO: ON"
        TweenService:Create(autoBtn,TweenInfo.new(0.2),{BackgroundColor3=Color3.fromRGB(90,40,180)}):Play()
        startAuto()
    else
        autoBtn.Text="AUTO: OFF"
        TweenService:Create(autoBtn,TweenInfo.new(0.2),{BackgroundColor3=AC}):Play()
        if autoConn then autoConn:Disconnect() autoConn=nil end
    end
end)

-- Sync visuel auto
task.spawn(function()
    local last=desyncOn
    while main.Parent do
        if desyncOn~=last then
            last=desyncOn
            updateOnBtn()
        end
        task.wait(0.05)
    end
end)

