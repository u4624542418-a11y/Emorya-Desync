    pcall(function() raknet.desync(true) end)
    pcall(function() hum:UnequipTools() end)

    -- Vert
    lbl.TextColor3=GN
    TweenService:Create(ms,TweenInfo.new(0.3),{Color=GN}):Play()
    TweenService:Create(main,TweenInfo.new(0.3),{BackgroundColor3=Color3.fromRGB(10,30,10)}):Play()
end)
