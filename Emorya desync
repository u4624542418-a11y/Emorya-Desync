local Players=game:GetService("Players")
local TweenService=game:GetService("TweenService")
local UserInputService=game:GetService("UserInputService")
local RunService=game:GetService("RunService")
local player=Players.LocalPlayer

local desyncOn=false

local AC=Color3.fromRGB(120,80,255)
local WH=Color3.fromRGB(255,255,255)
local RD=Color3.fromRGB(220,60,60)
local GN=Color3.fromRGB(80,220,80)

local function makeDraggable(frame)
    local drag,ds,dp=false,nil,nil
    frame.InputBegan:Connect(function(i)
        if i.UserInputType==Enum.UserInputType.MouseButton1 or i.UserInputType==Enum.UserInputType.Touch then
            drag=true ds=i.Position dp=frame.Position
            i.Changed:Connect(function()
                if i.UserInputState==Enum.UserInputState.End then drag=false end
            end)
        end
    end)
    UserInputService.InputChanged:Connect(function(i)
        if drag and(i.UserInputType==Enum.UserInputType.MouseMovement or i.UserInputType==Enum.UserInputType.Touch) then
            local d=i.Position-ds
            frame.Position=UDim2.new(dp.X.Scale,dp.X.Offset+d.X,dp.Y.Scale,dp.Y.Offset+d.Y)
        end
    end)
end

-- GUI
local sg=Instance.new("ScreenGui",player.PlayerGui)
sg.Name="UchiwaDesync" sg.ResetOnSpawn=false

local main=Instance.new("Frame",sg)
main.Size=UDim2.new(0,70,0,25)
main.Position=UDim2.new(0.5,-35,0.5,-12)
main.BackgroundColor3=Color3.fromRGB(10,10,18)
main.BackgroundTransparency=0.1 main.BorderSizePixel=0
local co=Instance.new("UICorner",main) co.CornerRadius=UDim.new(0,8)
local ms=Instance.new("UIStroke",main) ms.Color=AC ms.Thickness=1.5
makeDraggable(main)

local btn=Instance.new("TextButton",main)
btn.Size=UDim2.new(1,0,1,0)
btn.BackgroundTransparency=1
btn.Text="DESYNC"
btn.TextColor3=RD
btn.Font=Enum.Font.GothamBlack
btn.TextSize=11
btn.BorderSizePixel=0
btn.AutoButtonColor=false

local function setOn()
    desyncOn=true
    pcall(function() raknet.desync(true) end)
    btn.TextColor3=GN
    TweenService:Create(ms,TweenInfo.new(0.2),{Color=GN}):Play()
    TweenService:Create(main,TweenInfo.new(0.2),{BackgroundColor3=Color3.fromRGB(10,30,10)}):Play()
end

local function setOff()
    desyncOn=false
    pcall(function() raknet.desync(false) end)
    btn.TextColor3=RD
    TweenService:Create(ms,TweenInfo.new(0.2),{Color=RD}):Play()
    TweenService:Create(main,TweenInfo.new(0.2),{BackgroundColor3=Color3.fromRGB(10,10,18)}):Play()
end

-- Clic manuel = toggle OFF seulement si ON
btn.MouseButton1Click:Connect(function()
    if desyncOn then setOff() end
end)

-- Détection Quantum Cloner dans les mains
RunService.Heartbeat:Connect(function()
    if desyncOn then return end -- déjà ON, rien à faire
    local char=player.Character if not char then return end
    local cloner=char:FindFirstChild("Quantum Cloner")
    if cloner then
        setOn()
    end
end)
