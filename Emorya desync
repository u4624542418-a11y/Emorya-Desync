-- Cherche le bouton Change With Clone dans le GUI
local function findChangeBtn()
    for _,gui in pairs(player.PlayerGui:GetDescendants()) do
        if gui:IsA("TextButton") and gui.Text:lower():find("change") then
            return gui
        end
        if gui:IsA("ImageButton") then
            local lbl=gui:FindFirstChildWhichIsA("TextLabel",true)
            if lbl and lbl.Text:lower():find("change") then
                return gui
            end
        end
    end
    return nil
end

