        while active do
            TweenService:Create(statusDot,TweenInfo.new(0.5,Enum.EasingStyle.Sine,Enum.EasingDirection.InOut),{BackgroundTransparency=0.6}):Play()
            task.wait(0.5)
            TweenService:Create(statusDot,TweenInfo.new(0.5,Enum.EasingStyle.Sine,Enum.EasingDirection.InOut),{BackgroundTransparency=0}):Play()
            task.wait(0.5)
        end
    end)
end

