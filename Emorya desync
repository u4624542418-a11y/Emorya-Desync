local function setMode(mode)
    currentMode=mode
    local btns={Carpet=modeCarpetBtn,Clone=modeCloneBtn,Reset=modeResetBtn}
    for m,btn in pairs(btns) do
        if m==mode then
            TweenService:Create(btn,TweenInfo.new(0.15),{BackgroundColor3=AC,BackgroundTransparency=0.1}):Play()
            btn.TextColor3=WH
        else
            TweenService:Create(btn,TweenInfo.new(0.15),{BackgroundColor3=BT,BackgroundTransparency=0.1}):Play()
            btn.TextColor3=GR
        end
    end
end
